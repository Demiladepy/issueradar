# Oxlo AI
OXLO_API_KEY=your_oxlo_api_key_here
OXLO_BASE_URL=https://portal.oxlo.ai/v1
OXLO_MODEL=oxlo-1

# GitHub App
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_TOKEN=your_github_pat_for_local_dev

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHANNEL_IDS=C01234567,C09876543

# Server
PORT=3000
WEBHOOK_PATH=/webhook

# Storage
DB_PATH=./issueradar.db

# Web dashboard backend URL (used by Next.js API routes)
BACKEND_URL=http://localhost:3000

# Daily digest
DIGEST_CRON=0 9 * * *
DIGEST_SLACK_CHANNEL=C01234567
