# Oxlo AI (required for /demo page and /api/analyze)
OXLO_API_KEY=your_oxlo_api_key_here
OXLO_BASE_URL=https://portal.oxlo.ai/v1
OXLO_MODEL=oxlo-1

# GitHub (optional — used to fetch private issue bodies from URLs)
GITHUB_TOKEN=your_github_pat

# Backend server URL (used by /api/stats and /api/digest proxy routes)
BACKEND_URL=http://localhost:3000
